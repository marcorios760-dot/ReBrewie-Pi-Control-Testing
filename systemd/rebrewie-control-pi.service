[Unit]
Description=ReBrewie Control Pi – Brewie+ local web controller
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/rebrewie-control-pi
EnvironmentFile=/opt/rebrewie-control-pi/.env
ExecStart=/opt/rebrewie-control-pi/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
